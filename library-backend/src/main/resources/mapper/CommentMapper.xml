<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.library.mapper.CommentMapper">
    
    <select id="selectCommentPage" resultType="com.library.entity.Comment">
        SELECT * FROM comment
        WHERE deleted = 0
        <if test="bookId != null">
            AND book_id = #{bookId}
        </if>
        ORDER BY created_at DESC
    </select>
</mapper>
